# YouTube Data API v3 key — used by scrape/fetchEpisodes.py
# Get one at https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here

# RSS feed URL for the podcast (from your podcast host)
RSS_FEED_URL=https://your-podcast-host.com/feed.rss

# Anthropic API key — used by analyze/analyzeEpisodes.py
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Groq API key (optional — only needed if using Groq-based features)
# Get one at https://console.groq.com/
GROQ_API_KEY=gsk_...

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:port/dbname
