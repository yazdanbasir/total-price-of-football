# Anthropic API key — used by the chatbot endpoint
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:port/dbname

# Comma-separated list of allowed frontend origins (no trailing slashes)
# Local dev default is set in code; override this in production with your Vercel URL
# Example: https://your-app.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=https://your-app.vercel.app
